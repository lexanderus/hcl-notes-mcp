# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE
.idea/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
logs/

# Sandbox NSF files (binary, not committed — generated by tools/init-sandbox.cmd + SandboxFixtureBuilder)
tests/sandbox/Data/*.nsf
tests/sandbox/Data/*.ntf
tests/sandbox/id/sandbox.id
tests/sandbox/*.lck
tests/sandbox/notes.lck

# Notes lock file
notes.lck
~notes.lck

# OS
.DS_Store
Thumbs.db

# HCL Notes proprietary libraries (licensed, must be supplied by user from local Notes install)
lib/Notes.jar
lib/corba-omgapi.jar

# Extracted fat-jar artifacts from manual `jar -xf` — never commit
BOOT-INF/
META-INF/
org/

# Local agent / IDE state
.claude/
.goose/
.goosehints

# Compressed log archives
*.gz

# Personal data dumps
vacation_balances.txt
